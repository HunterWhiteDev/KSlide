    "run": "scripts/start.sh",
    "uninstall": "scripts/uninstall.sh",
    "restart": "scripts/restart.sh"
  },
  "devDependencies": {
    "esbuild": "^0.13.14",
    "kwin-types": "^0.1.1",
    "typescript": "^4.5.2"
  }
