{
  "name": "KSlide",
  "displayName": "Kslide",
  "version": "1.0.0",
  "description": "A Sliding Window Manager for KWin",
  "author": "HunterWhiteDev",
  "license": "GPL-2.0-only",
  "main": "contents/code/main.js",
  "scripts": {
    "lint": "tsc --noEmit",
    "compile": "esbuild --minify --bundle src/main.ts --outfile=package/contents/code/main.js --format=esm --platform=neutral",
